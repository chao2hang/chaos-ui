#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

echo ""
echo "=================================================================="
echo "  🚀 [Husky] Pre-push (fast gate)                                 "
echo "  Verification: pnpm run typecheck && pnpm run lint               "
echo "  Before opening a PR, run: pnpm run check:push                   "
echo "=================================================================="
echo ""

pnpm run typecheck && pnpm run lint

if [ $? -ne 0 ]; then
  echo ""
  echo "❌ [Error] Pre-push checks failed. Please fix the errors before pushing!"
  echo ""
  exit 1
fi

echo ""
echo "✅ [Success] Fast gate passed. Proceeding with push."
echo "   Tip: pnpm run check:push  (full local gate before PR)"
echo "        gh pr checks --watch (after PR is open)"
echo ""

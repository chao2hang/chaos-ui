{
  "name": "Chaos UI",
  "version": "1.0.0-beta.0",
  "description": "Enterprise-grade React/Next.js component library for ERP & business systems",
  "type": "library",
  "framework": "react",
  "language": "typescript",
  "styling": "tailwindcss",
  "packageManager": "npm",
  "entryPoints": {
    "ui": "components/ui/index.ts",
    "business": "components/business/index.ts",
    "hooks": "hooks/index.ts",
    "lib": "lib/index.ts"
  },
  "conventions": {
    "imports": "@/ alias for project-local source",
    "exports": "named exports only (no default exports)",
    "variants": "cva for component variants",
    "className": "cn() from @/lib/utils for merging",
    "primitives": "@base-ui/react for headless components",
    "identification": "data-slot attribute on root element",
    "docs": "JSDoc with @component/@category/@since/@example"
  },
  "scripts": {
    "dev": "storybook dev -p 6006",
    "test": "vitest run",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint && npm run lint:css && npm run lint:deps && npm run check:no-bom",
    "build:pkg": "tsup",
    "build-storybook": "storybook build"
  },
  "indexes": {
    "components": "./COMPONENT_INDEX.md",
    "hooks": "./HOOKS_INDEX.md",
    "lib": "./LIB_INDEX.md"
  }
}

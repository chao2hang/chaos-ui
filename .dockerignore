# Dependencies — exclude all node_modules at any level
**/node_modules
.pnpm-store

# Build outputs — exclude at any level
**/.next
**/storybook-static
**/dist
**/out
**/.turbo
output

# Git
.git
.gitignore

# IDE
.vscode
.idea
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Docker
Dockerfile
docker-compose*.yml
.dockerignore

# Documentation
*.md
!README.md

# Tests
**/coverage
.nyc_output
*.test.*
*.spec.*
vitest.config.ts
vitest.setup.ts
vitest.shims.d.ts

# Config files that aren't needed in production
.eslintrc*
eslint.config.*
.prettierrc*
prettier.config.*
tailwind.config.*
components.json
# postcss.config.* is needed by Next.js and Storybook for CSS processing — DO NOT exclude
# tsconfig.json is needed by Next.js for path resolution (@/ alias)
!apps/docs/tsconfig.json

# Storybook source — apps/docs/src 内的 .stories.tsx 是文档站 live preview 的
# 构建期输入(generate-component-story-previews.mjs 读取它),必须保留。
# 根目录 src/stories/ 仅供根 Storybook 构建用,已被 build-storybook 产物替代。
apps/docs/stories

# Temp files
tmp
temp
*.log
tmp_ci_*.txt
docker-build.log

# Agent / MCP / tooling artifacts (not needed in Docker build)
.agents
.codex
.claude
.codegraph
.detection
.playwright-mcp
.well-known
.workbuddy
.joycode
.changeset
.husky

# CI / scripts not needed in Docker
e2e
docs
designs
scripts/visual-audit.cjs

{
  "name": "chaos-ui-workspace",
  "private": true,
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.5.0",
  "scripts": {
    "dev": "pnpm --filter chaos-ui-docs storybook",
    "build": "pnpm --filter chaos-design-ui build && pnpm --filter chaos-ui-docs build",
    "build:lib": "pnpm --filter chaos-design-ui build",
    "storybook": "pnpm --filter chaos-ui-docs storybook",
    "build-storybook": "pnpm --filter chaos-ui-docs build-storybook",
    "test-storybook": "pnpm --filter chaos-ui-docs test-storybook",
    "lint": "pnpm --filter chaos-ui-docs lint",
    "audit": "pnpm audit --prod",
    "audit:fix": "pnpm audit --prod --fix"
  }
}
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist/types",
    "rootDir": ".",
    "incremental": false,
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "components/**/*.ts",
    "components/**/*.tsx",
    "hooks/**/*.ts",
    "hooks/**/*.tsx",
    "lib/**/*.ts",
    "package/**/*.ts",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    ".next",
    "storybook-static",
    "apps/**",
    "packages/**",
    "**/*.test.*",
    "**/*.stories.*",
    "**/*.spec.*"
  ]
}
